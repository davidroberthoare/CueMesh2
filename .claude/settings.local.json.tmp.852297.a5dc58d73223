{
  "permissions": {
    "allow": [
      "Bash(xargs ls -la)",
      "Bash(cargo build *)",
      "Bash(timeout 25 cargo run -q -p cuemesh2-media --example play_file -- ~/cuemesh_media/test1.mp4 6)",
      "Bash(pkill -f \"gst-launch-1.0\")",
      "Bash(gst-inspect-1.0 intervideosrc *)",
      "Bash(echo \"exit: $?\")",
      "Bash(timeout 40 cargo run -q -p cuemesh2-media --example crossfade -- ~/cuemesh_media/countdown.mp4 ~/cuemesh_media/test1.mp4 2000)",
      "Bash(git add *)",
      "Bash(git commit -q -m ' *)"
    ]
  }
}
